{
  // You can name this file tsconfig.json or tsconfig.app.json—Next.js will detect it automatically.
  "compilerOptions": {
    // Target modern JavaScript features. 'ESNext' is common, but you can adjust if you need older browser support.
    "target": "ESNext",
    // Include DOM libraries plus modern JS features.
    "lib": ["dom", "dom.iterable", "esnext"],
    // Use ES modules (recommended for Next.js).
    "module": "ESNext",
    // Determine how modules are resolved. 'NodeNext' is a good fit for modern Node, but 'node' is also common.
    "moduleResolution": "node",

    // ****************************
    //   Strictness & Quality
    // ****************************
    // Enforces strict type-checking for a safer, more robust codebase.
    "strict": true,
    // Helps prevent casing mismatches in import statements.
    "forceConsistentCasingInFileNames": true,
    // Skips type-checking in your node_modules. Speeds up builds without usually harming correctness.
    "skipLibCheck": true,

    // ****************************
    //   JSX / React Settings
    // ****************************
    // For Next.js, 'preserve' is usually recommended so Next can handle transforming your JSX.
    "jsx": "preserve",

    // ****************************
    //   Other Helpful Flags
    // ****************************
    // If true, TypeScript will allow importing .js files in addition to .ts/.tsx.
    // You can set this to false if your project is 100% TypeScript.
    "allowJs": true,
    // Disables emitting .js files on build (Next.js handles bundling itself).
    "noEmit": true,
    // Ensures each file is treated as its own module. Helps catch certain type errors, especially in monorepos.
    "isolatedModules": true,
    // Allows default imports from modules with no default export. Helps avoid many friction points in TS.
    "esModuleInterop": true,
    // Support importing JSON files directly.
    "resolveJsonModule": true
  },

  // ************************************
  //   Specify Which Files to Include
  // ************************************
  "include": [
    // This is generated by Next.js for types—keep it here.
    "next-env.d.ts",
    // All .ts, .tsx files in your project
    "**/*.ts",
    "**/*.tsx",
    // For Next.js 13 app router type definitions
    ".next/types/**/*.ts"
  ],
  // Exclude node_modules to speed up compilation
  "exclude": ["node_modules"]
}

