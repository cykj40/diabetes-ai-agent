generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ChatMessage {
    id        String   @id @default(uuid())
    sessionId String
    type      String // 'human' or 'ai'
    content   String
    timestamp DateTime @default(now())

    @@index([sessionId])
}

model BloodSugarReading {
    id         String   @id @default(uuid())
    sessionId  String
    userId     String // Required field
    value      Float
    trend      String
    timestamp  DateTime
    analyzed   Boolean  @default(false)
    isEmbedded Boolean  @default(false)
    analysis   Json? // Stores the AI analysis results

    @@unique([userId, timestamp])
    @@index([sessionId])
    @@index([timestamp])
    @@index([userId])
}

model DexcomToken {
    id           String   @id @default(uuid())
    userId       String   @unique
    accessToken  String
    refreshToken String
    expiresAt    DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([userId])
}
