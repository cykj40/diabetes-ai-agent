generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id        String    @id @default(uuid())
    email     String    @unique
    password  String
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    sessions  Session[]
}

model Session {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([userId])
}

model ChatMessage {
    id        String   @id @default(uuid())
    sessionId String
    type      String // 'human' or 'ai'
    content   String
    timestamp DateTime @default(now())

    @@index([sessionId])
}

model BloodSugarReading {
    id         String   @id @default(uuid())
    sessionId  String
    userId     String // Required field
    value      Float
    trend      String
    timestamp  DateTime
    analyzed   Boolean  @default(false)
    isEmbedded Boolean  @default(false)
    analysis   Json? // Stores the AI analysis results

    @@unique([userId, timestamp])
    @@index([sessionId])
    @@index([timestamp])
    @@index([userId])
}

model DexcomToken {
    id           String   @id @default(uuid())
    userId       String   @unique
    accessToken  String
    refreshToken String
    expiresAt    DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([userId])
}

model PelotonIntegration {
    id            String   @id @default(uuid())
    userId        String   @unique
    username      String?
    password      String?
    sessionCookie String?
    isActive      Boolean  @default(false)
    lastUpdated   DateTime @default(now())
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([userId])
}

model BloodWorkRecord {
    id             String           @id @default(uuid())
    userId         String // Link to user
    name           String // Name of the lab report
    date           DateTime // Date of the blood work
    fileName       String? // Original filename
    fileType       String? // 'csv' or 'pdf'
    interpretation String? // AI-generated interpretation
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    values         BloodWorkValue[] // Related test values

    @@index([userId])
    @@index([date])
    @@index([createdAt])
}

model BloodWorkValue {
    id           String          @id @default(uuid())
    recordId     String // Foreign key to BloodWorkRecord
    name         String // Name of the test (e.g., "Glucose", "HbA1c")
    value        String // Value as string (can be numeric or text)
    numericValue Float? // Parsed numeric value for queries
    unit         String // Unit of measurement
    normalRange  String? // Normal range if provided
    isAbnormal   Boolean? // Whether the value is abnormal
    category     String? // Category like 'diabetes', 'cholesterol', etc.
    createdAt    DateTime        @default(now())
    record       BloodWorkRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

    @@index([recordId])
    @@index([name])
    @@index([isAbnormal])
    @@index([category])
    @@index([numericValue])
}
